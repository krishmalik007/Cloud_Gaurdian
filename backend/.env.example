# ============================================================
# Cloud Guardian - Environment Configuration
# ============================================================
# Copy this file to .env and replace placeholder values
# cp .env.example .env
# ============================================================

# Application Config
APP_NAME=CloudGuardian
APP_VERSION=1.0.0
DEBUG=False

# FastAPI Config
HOST=0.0.0.0
PORT=8000

# Kafka Config
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=cloud-logs

# OpenSearch Config
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=CHANGE_ME_STRONG_PASSWORD
OPENSEARCH_USE_SSL=False
OPENSEARCH_VERIFY_CERTS=False

# JWT Config (generate a strong key: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_secrets_token_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Logging Config
LOG_LEVEL=INFO
LOG_FILE=app.log

# Docker / Kafka
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT=100/minute
